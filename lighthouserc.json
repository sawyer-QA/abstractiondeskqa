{
  "ci": {
    "collect": {
      "staticDistDir": ".",
      "url": [
        "/index.html",
        "/lookup.html",
        "/sep1-tool.html",
        "/lkw-tool.html",
        "/cmo-tool.html",
        "/hbips-tool.html",
        "/abstractly.html",
        "/404.html"
      ]
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": ".*",
          "assertions": {
            "categories:performance": ["warn", { "minScore": 0.9 }],
            "categories:accessibility": ["error", { "minScore": 0.95 }]
          }
        },
        {
          "matchingUrlPattern": "/404\\.html$",
          "assertions": {
            "categories:accessibility": ["warn", { "minScore": 0.95 }]
          }
        }
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
